      \u6309\u7A7A\u767D\u9375\u7E7C\u7E8C\uFF01\u5F80\u5DE6\u8D70\n(\u53BB\u91E3\u9B5A)\r\n\u829D\u9EBB\uFF1A\u6211\u8A18\u5F97\u6C92\u932F\uFF0C\u6CBF\u8457\u9053\u8DEF\u8D70\u5C31\u53EF\u4EE5\u5230\u6CB3\u908A\u770B\u5230\u8001\u7238\u4E86\r\n\u8001\u4EBA\uFF1A\u4E2D\u5348\u597D\uFF0C\u829D\u9EBB\uFF0C\u6700\u8FD1\u5982\u4F55\u554A\r\n\u829D\u9EBB\uFF1A\u5F88\u4E0D\u932F\r\n\u8001\u4EBA\uFF1A\u53C8\u53BB\u627E\u4F60\u8001\u7238\u4E00\u8D77\u91E3\u9B5A\u53BB\u4E86?\r\n\u5C0D\u963F
      \u4ECA\u5929\u53EF\u4E0D\u80FD\u7A7A\u624B\u800C\u6B78\r\n\u4E7E\u4F60\u5C41\u4E8B\u554A
      \u8001\u6771\u897F\r\n\u8001\u4EBA\uFF1A\u5475\u5475 \u795D\u4F60\u597D\u904B\r\r\n\u9ED1\u72D7\uFF1A\u6C6A\u6C6A\u6C6A\r\n\u829D\u9EBB\uFF1A\r\nA.
      \u4E56\u72D7\u72D7\r\nB. \u6EFE\u958B \r\n\u8001\u7238\uFF1A\u4F60\u4F86\u4E86\u963F\r\n\u8001\u7238\uFF1A\u4F60\u7684\u9B5A\u7AFF\u5728\u9019\u88E1\r\n\u829D\u9EBB\uFF1A\u91E3\u9B5A\u55BD\r\n\r\n\u8001\u7238\uFF1A\u597D\u4E86\uFF0C\u660E\u5929\u518D\u4F86\u5427\uFF0C\u4ECA\u5929\u6536\u7372\u4E0D\u932F\r\n\u829D\u9EBB\uFF1A\u597D\u554A\u829D\u9EBB\uFF1A\u4ECA\u5929\u5929\u6C23\u6709\u9EDE\u7CDF\u7CD5\uFF0C\u4F46\u4E0D\u5F71\u97FF\u6211\u91E3\u9B5A\u7684\u5FC3\u60C5\r\n\r\n\u8001\u982D\uFF1A\u829D\u9EBB\uFF0C\u9019\u500B\u7D66\u4F60\uFF0C\u525B\u525B\u8DEF\u4E0A\u4E00\u500B\u5947\u602A\u7684\u4EBA\u7D66\u6211\u7684\uFF0C\u9084\u5C0D\u6211\u8AAA\u8056\u8A95\u7BC0\u5FEB\u6A02\r\n\r\n\u829D\u9EBB\uFF1A\u9177\r\n\u829D\u9EBB\uFF1A\u4F46\u4F60\u8981\u7559\u610F\u4E00\u4E0B\u653F\u5E9C\u7684\u516C\u544A\uFF0C\u61C9\u8A72\u8AAA\u8036\u8A95\u7BC0\u5FEB\u6A02\r\n\u829D\u9EBB\uFF1A\u6211\u6536\u4E0B\u4F60\u7684\u597D\u610F\u4E86\r\n\r\n\u829D\u9EBB\uFF1A\u9019\u4E9B\u662F\u4EC0\u9EBC\u554A\uFF0C\u592A\u6050\u6016\u4E86\u5427\r\r\n\u7236\u89AA\uFF1A\u6211\u4E5F\u4E0D\u77E5\u9053\uFF0C\u9019\u4E9B\u9B5A\u9577\u7684\u90FD\u883B\u919C\u7684\r\n\u7236\u89AA\uFF1A\u770B\u770B\u9019\u9B5A\u56DE\u53BB\u80FD\u4E0D\u80FD\u8CE3\u500B\u597D\u50F9\u9322\r\n\u829D\u9EBB\uFF1A\u6211\u89BA\u5F97\u9019\u4E9B\u9B5A\u53EF\u4EE5\u76F4\u63A5\u4E1F\u56DE\u53BB\r\n\u7236\u89AA\uFF1A\u4E0D\u597D\u8AAA\uFF0C\u641E\u4E0D\u597D\u662F\u7A00\u6709\u7684\u9B5A\r\n\u4E00\u6BB5\u6642\u9593\u5F8C...
      (\u9ED1\u5C4F)\r\r\n\u7236\u89AA\uFF1A\u4ECA\u5929\u6536\u7A6B\u4E0D\u662F\u5F88\u597D\uFF0C\u660E\u5929\u518D\u4F86\u6700\u5F8C\u4E00\u6B21\uFF0C\u6211\u5011\u5C31\u6E96\u5099\u63DB\u5730\u9EDE\u5427\r\n\u829D\u9EBB\uFF1A\u597D"
