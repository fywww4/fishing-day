    characterSetSelectionMode: 7
    characterSequence: "\r\u963F\u4F2F\uFF0C\u9019\u662F\u7D66\u4F60\u7684\uFF0C\u6211\u7236\u89AA\u8AAA\u8981\u8DDF\u611F\u8B1D\u4F60\u7684\u5E6B\u5FD9\u767C\u751F\u4EC0\u9EBC\u4E8B\u60C5\u4E86\u963F\uFF0C\u70BA\u4F55\u90FD\u662F\u8840\u963F\u963F\u963F\u963F\u963F?!\u5E36\u56DE\u53BB\u6293\u5230\u540C\u5925\u53EF\u662F\u4ED6\u53EA\u662F\u4E00\u500B\u5C0F\u5B69\u6B38\u5171\u532A\u4E0D\u5206\u5E74\u9F61\u5225\u5FD8\u8A18\u4E86\u7B49\u7B49\u90A3\u662F\u4EC0\u9EBC\u4F60\u4E0D\u8981\u904E\u4F86\u554A!!!\u6CBF\u8457\u9053\u8DEF\u7136\u5F8C\u5F80\u5DE6\u8D70\u5C31\u53EF\u4EE5\u5230\u6CB3\u908A\u770B\u5230\u8001\u7238\u4E86\u8B66\u8ECA\u8B66\u5BDF\u6700\u8FD1\u5982\u4F55\u554A\u9084\u53EF\u4EE5\u5566\u4F60\u8DDF\u8A18\u5F97\u8981\u56DE\u4F86\u554A\u4F60\u963F\u7238\u4E00\u8D77\u91E3\u9B5A\u53BB\u4E86?\u5509\u5466\u5DEE\u4E0D\u591A\u4E86\uFF0C\u660E\u5929\u518D\u4F86\u5427\uFF0C\u56DE\u53BB\u5403\u98EF\u4E86\u963F\u9019\u4E9B\u9B5A\u76F4\u63A5\u4E1F\u56DE\u53BB\u5566\u514D\u5566\uFF0C\u641E\u4E0D\u597D\u662F\u7A00\u600E\u6709\u7684\u9B5A\u592A\u6162\u4E86\u5427\u8056\u8A95\u5E3D?\uFF0C\u9748\u654F\u5EA6\u4ECA\u5929\u8B9A\u7684\u54E9\uFF0C\u4F86\u500B\u6700\u5F8C\u6536\u5C3E\u54ED\u9080\uFF0C\u592A\u96D6\u5C0F\u4E86\u5427\uFF0C\u660E\u5929\u518D\u9019\u6A23\u5C31\u6E96\u5099\u63DB\u5730\u9EDE\u5427\u4ECA\u5929\u5929\u6C23\u592A\u7CDF\u4E86\u5427\u689D\u5B50\u8A9E\u8A00:
      \u7E41\u9AD4\u4E2D\u6587 \u81EA\u5DF1\u8A18\u5F97\u8981\u5403\u98FD\u98EF\u963F\u514D\u5566\u653E\u9019\u908A\u5566\uFF0C\u63B0\u63B0\u591A\u8B1D\u5566
      ().?AB\u4E00\u4E0A\u4E0B\u4E0D\u4E1F\u4E2D\u4E56\u4E5F\u4E7E\u4E86\u4E8B\u4E9B\u4EAB\u4EBA\u4EC0\u4ECA\u4ED6\u4EE5\u4F2F\u4F46\u4F55\u4F60\u4F86\u500B\u5011\u5099\u50CF\u50F9\u516C\u5175\u518D\u5206\u5230\u525B\u5348\u53BB\u53C8\u53EF\u540C\u5427\u544A\u5462\u5475\u54EA\u554A\u5566\u5594\u55BD\u56DE\u5728\u5730\u5925\u5929\u592A\u5947\u597D\u5982\u59CB\u5C0D\u5C0F\u5C31\u5C3E\u5C41\u5C4F\u5DE6\u5E36\u5E6B\u5E9C\u5F71\u5F80\u5F88\u5F8C\u5F97\u5F9E\u5FC3\u5FEB\u6016\u602A\u6050\u60C5\u610F\u61B2\u61C9\u6211\u624B\u627E\u628A\u6293\u62FF\u6309\u63A5\u63DB\u641E\u6536\u653F\u660E\u662F\u6642\u6700\u6709\u6771\u677F\u6A02\u6B21\u6B78\u6BB5\u6C23\u6C6A\u6C92\u6CB3\u6CBF\u6E96\u6EFE\u7236\u7238\u72D7\u7372\u7528\u7559\u767D\u7684\u76F4\u770B\u7761\u77E5\u795D\u798F\u7A00\u7A6B\u7A7A\u7AFF\u7B97\u7BC0\u7CD5\u7CDF\u7D66\u7E7C\u7E8C\u7F8E\u8001\u800C\u8036\u8056\u80FD\u829D\u8457\u883B\u8840\u88E1\u897F\u8981\u89AA\u89BA\u8A18\u8A72\u8A95\u8AAA\u8B1D\u8CA9\u8CE3\u8D70\u8D77\u8DD1\u8DDF\u8DE1\u8DEF\u8E66\u8FD1\u9019\u904B\u9053\u9084\u908A\u90FD\u9177\u919C\u91E3\u9322\u932F\u9375\u9577\u958B\u9593\u95C6\u963F\u97FF\u982D\u9B5A\u9EBB\u9EBC\u9ED1\u9EDE\uFF01\uFF0C\uFF1A\u9019\u500B\u96FB\u5B50\u9396...\u597D\u50CF\u9700\u8981\u8F38\u51654\u4F4D\u6578\u7684\u5BC6\u78BC\u3002\u89E3\u9396\u6210\u529F\uFF01\u5BC6\u78BC\u932F\u8AA4\uFF01\u9019\u5F35\u7D19\u5BEB\u8AAA\uFF0C\u627E\u5230\u756B\uFF0C\u6703\u6709\u7B54\u6848\u7684\u9019\u628A\u69CC\u5B50...\u770B\u8D77\u4F86\u53EF\u4EE5\u628A\u9580\u4E0A\u7684\u6728\u677F\u7D66\u6572\u6389\u3002\u9019\u628A\u9470\u5319...\u8A66\u8A66\u770B\u80FD\u4E0D\u80FD\u6253\u958B\u9580\u628A\u4E0A\u7684\u9396\u982D\u5427\u9019\u500B\u756B\u597D\u50CF\u6709\u9EDE\u592A\u9AD8\u4E86\u6211\u9700\u8981\u4E00\u500B\u6771\u897F\u588A\u8173\uFF0C\u6905\u5B50\u4E4B\u985E\u7684\uFF1F\u770B\u4F86\u9700\u8981\u628A\u65C1\u908A\u7684\u5BC6\u78BC\u9396\u89E3\u9664\u3001\u9396\u982D\u62C6\u6389\u3001\u6728\u677F\u6572\u6389\u9580\u88AB\u9396\u4F4F\u4E86\u4F